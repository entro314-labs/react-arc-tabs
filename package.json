{
  "name": "@entro314labs/react-arc-tabs",
  "version": "1.1.1",
  "private": false,
  "description": "Reusable arc-style tabs component for React and Next.js projects",
  "keywords": [
    "accessible",
    "component-library",
    "nextjs",
    "react",
    "tabs",
    "tailwindcss",
    "ui"
  ],
  "homepage": "https://github.com/entro314-labs/react-arc-tabs#readme",
  "bugs": {
    "url": "https://github.com/entro314-labs/react-arc-tabs/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/entro314-labs/react-arc-tabs.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/ArcTabs.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsdown && cp src/ArcTabs.css dist/ArcTabs.css",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "lint:fix-unsafe": "oxlint --import-plugin   --type-aware --type-check --vitest-plugin --fix --fix-suggestions --fix-dangerously .",
    "check:fix-suggestions": "oxlint --import-plugin   --type-aware --type-check --vitest-plugin --fix --fix-suggestions . && oxfmt --write ."
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^19.0.0 || ^19.2.4",
    "react-dom": "^19.0.0 || ^19.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.1"
}
